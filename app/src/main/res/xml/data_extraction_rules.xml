<?xml version="1.0" encoding="utf-8"?>
<!-- Backup and device-transfer rules (API 31+). Same scope as backup_rules.xml. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="clear_ledger_database" />
        <include domain="database" path="clear_ledger_database-shm" />
        <include domain="database" path="clear_ledger_database-wal" />
        <include domain="sharedpref" path="language_prefs" />
        <include domain="sharedpref" path="seeding_prefs" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="clear_ledger_database" />
        <include domain="database" path="clear_ledger_database-shm" />
        <include domain="database" path="clear_ledger_database-wal" />
        <include domain="sharedpref" path="language_prefs" />
        <include domain="sharedpref" path="seeding_prefs" />
    </device-transfer>
</data-extraction-rules>
